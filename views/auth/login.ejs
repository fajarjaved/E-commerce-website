<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%
    const prefilledEmail = typeof email !== "undefined"
      ? email
      : (typeof req !== "undefined" && req.query && req.query.email ? req.query.email : "");
  %>

  <div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-sm p-4" style="width: 100%; max-width: 420px;">
      <h2 class="text-center mb-4">Login</h2>

      <form action="/auth/login" method="POST">
        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <input
            type="email"
            name="email"
            class="form-control"
            placeholder="Enter your email"
            required
            value="<%= prefilledEmail %>"
            pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
          >
        </div>

        <div class="mb-3 position-relative">
          <label for="password" class="form-label">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            class="form-control pe-5"
            placeholder="Enter your password"
            required
          >
          <i
            class="fa-solid fa-eye-slash"
            id="togglePassword"
            style="position: absolute; right: 15px; top: 40px; cursor: pointer;"
          ></i>
        </div>

        <button type="submit" class="btn btn-primary w-100">Login</button>

        <div class="mt-3 text-center">
          <p class="mt-3 mb-2">
            <a href="/auth/forgot-password" class="text-primary">Forgot your password?</a>
          </p>
        </div>

        <% if (prefilledEmail) { %>
          <div class="mt-3">
            <div class="border rounded p-3 bg-light">
              <p class="mb-2 small text-muted">
                Didn’t receive the verification email?
              </p>
              <form action="/auth/resend-verification" method="POST">
                <input type="hidden" name="email" value="<%= prefilledEmail %>">
                <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                  Resend Verification Email
                </button>
              </form>
            </div>
          </div>
        <% } %>

        <div class="mt-3 text-center">
          <p class="mb-0">
            Don't have an account?
            <a href="/auth/signup" class="text-decoration-none">Create Account</a>
          </p>
        </div>
      </form>
    </div>
  </div>

  <script>
    const togglePassword = document.querySelector("#togglePassword");
    const password = document.querySelector("#password");

    if (togglePassword && password) {
      togglePassword.addEventListener("click", function () {
        const type = password.getAttribute("type") === "password" ? "text" : "password";
        password.setAttribute("type", type);
        this.classList.toggle("fa-eye");
        this.classList.toggle("fa-eye-slash");
      });
    }
  </script>
</body>
</html>