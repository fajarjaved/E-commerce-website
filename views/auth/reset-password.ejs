
<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
  <div class="card shadow p-4 border-0" style="max-width: 420px; width: 100%; border-radius: 14px;">
    
    <!-- Heading -->
    <div class="text-center mb-3">
      <h3 class="fw-bold">Reset Password</h3>
      <p class="text-muted" style="font-size: 0.9rem;">Enter your new password below</p>
    </div>

    <!-- Form -->
    <form action="/auth/reset-password/<%= token %>" method="POST">
      <div class="mb-3">
        <label class="form-label fw-semibold">New Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter new password" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Confirm Password</label>
        <input type="password" name="confirm_password" class="form-control" placeholder="Re-enter new password" required>
      </div>

      <button type="submit" class="btn btn-primary w-100 fw-semibold">Reset Password</button>
    </form>

    <!-- Back Link -->
    <div class="text-center mt-3">
      <a href="/auth/login" class="text-decoration-none">Back to Login</a>
    </div>
  </div>
</div>
