




<div class="d-flex align-items-center justify-content-center vh-100 bg-white">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-sm border-0 rounded-3">
      <div class="card-body p-4">

    

        <!-- Title -->
        <h4 class="text-center mb-3 fw-semibold">Forgot Password</h4>
        <p class="text-muted small text-center mb-4">
          Enter your email to receive a password reset link.
        </p>

        <!-- Form -->
        <form action="/auth/forgot-password" method="POST">
          <div class="mb-3">
            <label for="email" class="form-label">Email Address</label>
            <input type="email" name="email" id="email" 
                   class="form-control" placeholder="you@example.com" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">
            Send Reset Link
          </button>
        </form>

        <!-- Footer -->
        <div class="mt-3 text-center">
          <a href="/auth/login" class="text-decoration-none">Back to Login</a>
        </div>

      </div>
    </div>
  </div>
</div>




