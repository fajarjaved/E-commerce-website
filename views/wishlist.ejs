<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wishlist</title>

  <style>
    :root{
      --bg:#f6f7fb;
      --card:#ffffff;
      --text:#111827;
      --muted:#6b7280;
      --border:#e5e7eb;
      --shadow: 0 10px 30px rgba(17,24,39,.08);
      --shadow2: 0 6px 18px rgba(17,24,39,.08);
      --radius: 16px;
      --primary:#111827; /* premium black */
      --primary2:#0b1220;
      --danger:#ef4444;
      --danger2:#dc2626;
      --accent:#2563eb;
    }

    body{
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Helvetica Neue", "Noto Sans", "Liberation Sans", sans-serif;
      margin:0;
      padding:0;
      background: var(--bg);
      color: var(--text);
    }

    .container{
      max-width: 1100px;
      margin: 28px auto;
      padding: 22px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .wishlist-header{
      text-align:center;
      margin-bottom: 18px;
    }
    .wishlist-header h1{
      font-size: 28px;
      letter-spacing: .08em;
      margin: 0 0 10px;
      text-transform: uppercase;
    }
    .wishlist-header p{
      margin:0;
      color: var(--muted);
      font-size: 14px;
    }

    .empty-message{
      text-align:center;
      font-size: 16px;
      color: var(--muted);
      margin: 30px 0;
      padding: 18px;
      background: #f9fafb;
      border: 1px dashed var(--border);
      border-radius: 14px;
    }

    .wishlist-list{
      display:flex;
      flex-direction:column;
      gap: 14px;
      margin-top: 18px;
    }

    .wishlist-item{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 14px;
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #fbfbfc;
      box-shadow: var(--shadow2);
      transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
    }
    .wishlist-item:hover{
      transform: translateY(-3px);
      background: #ffffff;
      box-shadow: 0 12px 26px rgba(17,24,39,.12);
    }

    .product-link{
      display:flex;
      align-items:center;
      gap: 14px;
      flex: 1;
      text-decoration:none;
      color: inherit;
      min-width: 0;
    }

    .product-link img{
      width: 92px;
      height: 124px;
      border-radius: 12px;
      object-fit: cover;
      background: #f3f4f6;
      border: 1px solid var(--border);
    }

    .wishlist-item-details{
      min-width: 0;
    }
    .wishlist-item-details h4{
      margin:0;
      font-size: 16px;
      font-weight: 700;
      line-height: 1.25;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 520px;
    }
    .wishlist-item-details p{
      margin: 6px 0 0;
      font-size: 13px;
      color: var(--muted);
      display:flex;
      gap: 10px;
      align-items:center;
      flex-wrap:wrap;
    }
    .price-badge{
      display:inline-flex;
      align-items:center;
      padding: 6px 10px;
      border-radius: 999px;
      background: #111827;
      color: #fff;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: .02em;
    }

    .wishlist-actions{
      display:flex;
      align-items:center;
      gap: 10px;
      flex-shrink: 0;
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap: 8px;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: #ffffff;
      color: var(--text);
      font-weight: 700;
      font-size: 13px;
      text-decoration:none;
      cursor:pointer;
      transition: transform .15s ease, background .15s ease, border-color .15s ease, box-shadow .15s ease;
      white-space: nowrap;
    }
    .btn:hover{
      transform: translateY(-1px);
      background: #f9fafb;
      border-color: #d1d5db;
      box-shadow: 0 10px 18px rgba(17,24,39,.08);
    }

    .btn-cart{
      background: linear-gradient(180deg, var(--primary), var(--primary2));
      color:#fff;
      border-color: transparent;
    }
    .btn-cart:hover{
      background: linear-gradient(180deg, #0b1220, #050913);
    }

    .btn-delete{
      background: #fff5f5;
      border-color: #fecaca;
      color: var(--danger2);
    }
    .btn-delete:hover{
      background: #ffecec;
      border-color: #fca5a5;
    }

    .home-button{
      display:flex;
      justify-content:center;
      margin-top: 22px;
    }
    .home-button a{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap: 10px;
      padding: 12px 18px;
      border-radius: 14px;
      background: #ffffff;
      color: var(--text);
      border: 1px solid var(--border);
      text-decoration:none;
      font-weight: 800;
      transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
    }
    .home-button a:hover{
      transform: translateY(-1px);
      background:#f9fafb;
      box-shadow: 0 12px 22px rgba(17,24,39,.10);
    }

    /* Responsive */
    @media (max-width: 768px){
      .container{ margin: 18px 12px; padding: 16px; }
      .wishlist-item{ flex-direction: column; align-items: stretch; }
      .wishlist-actions{ justify-content: flex-end; }
      .wishlist-item-details h4{ max-width: 100%; }
      .product-link img{ width: 100%; height: 220px; }
    }



 .btn-cart:hover{
  color: #b8eef8;   /* light grey text */
}


/* FIX - Modern Wishlist Title */

.wl-title-wrap{
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.wl-code{
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1.5px;
  color: #9ca3af;
}

.wl-title{
  margin: 0;
  font-size: 17px;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.3;
  position: relative;
}

/* subtle premium underline */
.wl-title::after{
  content: "";
  display: block;
  width: 40px;
  height: 2px;
  margin-top: 6px;
  background: linear-gradient(90deg, #6DC849, #3CB8D9);
  border-radius: 2px;
}
  </style>
</head>

<body>
  <div class="container">

    <div class="wishlist-header">
      <h1>Your Wishlist</h1>
      <p>Save your favorites — add them to cart anytime.</p>
    </div>

    <% if (products.length === 0) { %>
      <p class="empty-message">Your wishlist is empty.</p>
    <% } else { %>

      <div class="wishlist-list">
        <% products.forEach(item => { %>
          <div class="wishlist-item">

            <!-- Product -->
            <a href="/product/<%= item._id %>" class="product-link">
              <img src="<%= item.image %>" alt="Product Image">
              <div class="wishlist-item-details">
                <div class="wl-title-wrap">
                  
                  <h4 class="wl-title"><%= item.name %></h4>
                </div>
                <p>
                  <span class="price-badge">Rs <%= item.price %></span>
                  <span>Tap to view details</span>
                </p>
              </div>
            </a>

            <!-- Actions -->
            <div class="wishlist-actions">
              <!-- ✅ Add to Cart -->
              <a href="/cart/add/<%= item._id %>" class="btn btn-cart">
                 Add to Cart
              </a>

              <!-- Delete -->
              <a href="/wishlist/delete/<%= item._id %>" class="btn btn-delete" title="Remove from wishlist">
                 Remove
              </a>
            </div>

          </div>
        <% }); %>
      </div>

    <% } %>

    <div class="home-button">
      <a href="/">← Back to Home Page</a>
    </div>

  </div>
</body>
</html>