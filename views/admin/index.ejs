<style>
  .ad-wrap{
    padding: 6px 0 2px;
  }

  /* Hero */
  .ad-hero{
    position: relative;
    margin-bottom: 22px;
    padding: 30px 30px;
    background:
      radial-gradient(circle at top right, rgba(59,130,246,.08), transparent 30%),
      radial-gradient(circle at bottom left, rgba(16,185,129,.08), transparent 28%),
      linear-gradient(180deg, #ffffff, #f8fbff);
    border: 1px solid #e5e7eb;
    border-radius: 28px;
    box-shadow: 0 18px 45px rgba(15,23,42,.05);
    overflow: hidden;
  }

  .ad-hero::after{
    content: "";
    position: absolute;
    right: -40px;
    top: -40px;
    width: 180px;
    height: 180px;
    background: radial-gradient(circle, rgba(99,102,241,.10), transparent 68%);
    pointer-events: none;
  }

 .ad-hero-title{
  font-size: 40px;
  line-height: 1.08;
  font-weight: 600;
  color: #111827;
  margin: 0 0 10px;
  letter-spacing: -.3px;
}

  .ad-hero-sub{
    margin: 0;
    font-size: 16px;
    color: #6b7280;
    max-width: 720px;
    line-height: 1.7;
  }

  /* Stats */
  .ad-stats{
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
    margin-bottom: 22px;
  }

  .ad-stat{
    position: relative;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 22px;
    padding: 20px;
    box-shadow: 0 14px 34px rgba(0,0,0,.04);
    transition: all .18s ease;
    overflow: hidden;
  }

  .ad-stat:hover{
    transform: translateY(-3px);
    box-shadow: 0 18px 38px rgba(0,0,0,.07);
    border-color: #dbe2ea;
  }

  .ad-stat-top{
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    gap: 12px;
  }

  .ad-stat-icon{
    width: 52px;
    height: 52px;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: #0f172a;
    background: #eef4ff;
    border: 1px solid #dbe6fb;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.7);
  }

  .ad-stat.products .ad-stat-icon{
    background: #eef4ff;
    border-color: #dbe6fb;
  }

  .ad-stat.orders .ad-stat-icon{
    background: #eefbf3;
    border-color: #d8f2e3;
  }

  .ad-stat.pending .ad-stat-icon{
    background: #fff7ed;
    border-color: #fed7aa;
  }

  .ad-stat.stock .ad-stat-icon{
    background: #fef2f2;
    border-color: #fecaca;
  }

  .ad-stat-badge{
    padding: 7px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    color: #475569;
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    white-space: nowrap;
  }

  .ad-stat-number{
    margin: 0 0 4px;
    font-size: 30px;
    line-height: 1;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -.5px;
  }

  .ad-stat-label{
    margin: 0;
    font-size: 14px;
    color: #6b7280;
    line-height: 1.6;
  }

  /* Main Grid */
  .ad-main{
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 22px;
    margin-bottom: 22px;
  }

  .ad-card{
    position: relative;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 24px;
    padding: 24px;
    box-shadow: 0 14px 34px rgba(0,0,0,.05);
    transition: all .18s ease;
    overflow: hidden;
  }

  .ad-card:hover{
    transform: translateY(-3px);
    box-shadow: 0 20px 40px rgba(0,0,0,.08);
    border-color: #dbe2ea;
  }

  .ad-card-head{
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 18px;
  }

  .ad-card-title{
    margin: 0;
    font-size: 24px;
    line-height: 1.2;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -.3px;
  }

  .ad-card-sub{
    margin: 4px 0 0;
    font-size: 14px;
    color: #6b7280;
    line-height: 1.6;
  }

  .ad-badge{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    color: #334155;
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    white-space: nowrap;
  }

  /* Table */
  .ad-table{
    width: 100%;
    border-collapse: collapse;
  }

  .ad-table thead th{
    text-align: left;
    font-size: 12px;
    font-weight: 800;
    color: #64748b;
    padding: 12px 14px;
    background: #f8fafc;
    border-bottom: 1px solid #e5e7eb;
  }

  .ad-table thead th:first-child{
    border-top-left-radius: 14px;
  }

  .ad-table thead th:last-child{
    border-top-right-radius: 14px;
  }

  .ad-table tbody td{
    padding: 14px;
    font-size: 14px;
    color: #0f172a;
    border-bottom: 1px solid #eef2f7;
    vertical-align: middle;
  }

  .ad-table tbody tr:last-child td{
    border-bottom: none;
  }

  .ad-order-id{
    font-weight: 800;
    color: #111827;
  }

  .ad-status{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid transparent;
  }

  .ad-status.pending{
    color: #9a3412;
    background: #fff7ed;
    border-color: #fed7aa;
  }

  .ad-status.processing{
    color: #1d4ed8;
    background: #eff6ff;
    border-color: #bfdbfe;
  }

  .ad-status.delivered{
    color: #166534;
    background: #eefbf3;
    border-color: #bbf7d0;
  }

  /* Side widgets */
  .ad-side-stack{
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .ad-actions-list{
    display: grid;
    gap: 12px;
  }

  .ad-action-btn{
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid #e5e7eb;
    background: linear-gradient(180deg, #ffffff, #fbfdff);
    text-decoration: none !important;
    transition: all .18s ease;
    color: #0f172a !important;
  }

  .ad-action-btn:hover{
    transform: translateY(-2px);
    border-color: #d6dee8;
    box-shadow: 0 12px 24px rgba(0,0,0,.05);
    background: #fff;
  }

  .ad-action-left{
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .ad-action-icon{
    width: 42px;
    height: 42px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #f3f6fb;
    border: 1px solid #e5e7eb;
    font-size: 16px;
    color: #111827;
    flex-shrink: 0;
  }

  .ad-action-text strong{
    display: block;
    font-size: 14px;
    line-height: 1.3;
    color: #111827;
    margin-bottom: 2px;
  }

  .ad-action-text span{
    display: block;
    font-size: 12px;
    color: #6b7280;
    line-height: 1.5;
  }

  .ad-action-arrow{
    color: #94a3b8;
    font-size: 14px;
    flex-shrink: 0;
  }

  /* Low stock */
  .ad-alert-list{
    display: grid;
    gap: 12px;
  }

  .ad-alert-item{
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 14px 16px;
    border: 1px solid #f3d0d0;
    background: linear-gradient(180deg, #fffefe, #fff8f8);
    border-radius: 18px;
  }

  .ad-alert-left{
    min-width: 0;
  }

  .ad-alert-title{
    margin: 0 0 4px;
    font-size: 14px;
    font-weight: 800;
    color: #111827;
  }

  .ad-alert-text{
    margin: 0;
    font-size: 12px;
    color: #6b7280;
    line-height: 1.5;
  }

  .ad-alert-qty{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    color: #991b1b;
    background: #fee2e2;
    border: 1px solid #fecaca;
    white-space: nowrap;
  }

  /* Bottom note */
  .ad-note{
    margin-top: 4px;
    background: linear-gradient(180deg, #ffffff, #fbfdff);
    border: 1px solid #e5e7eb;
    border-radius: 22px;
    padding: 18px 20px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    box-shadow: 0 10px 24px rgba(0,0,0,.03);
  }

  .ad-note-icon{
    width: 42px;
    height: 42px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #f3f4f6;
    color: #111827;
    font-size: 16px;
    flex-shrink: 0;
  }

  .ad-note h6{
    margin: 0 0 5px;
    font-size: 15px;
    font-weight: 800;
    color: #111827;
  }

  .ad-note p{
    margin: 0;
    font-size: 14px;
    color: #6b7280;
    line-height: 1.65;
  }

  @media (max-width: 1200px){
    .ad-stats{
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 991px){
    .ad-main{
      grid-template-columns: 1fr;
    }

    .ad-hero-title{
      font-size: 34px;
    }
  }

  @media (max-width: 768px){
    .ad-table{
      min-width: 640px;
    }

    .ad-table-wrap{
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }

  @media (max-width: 576px){
    .ad-hero{
      padding: 24px 20px;
      border-radius: 22px;
    }

    .ad-card,
    .ad-stat{
      padding: 18px;
      border-radius: 20px;
    }

    .ad-stats{
      grid-template-columns: 1fr;
    }

    .ad-card-title{
      font-size: 22px;
    }

    .ad-hero-title{
      font-size: 30px;
    }

    .ad-hero-sub{
      font-size: 15px;
    }

    .ad-card-head{
      align-items: flex-start;
      flex-direction: column;
    }

    .ad-alert-item,
    .ad-action-btn{
      align-items: flex-start;
    }
  }
</style>

<div class="ad-wrap">
  <!-- Hero -->
  <div class="ad-hero">
    <h2 class="ad-hero-title">Welcome to your Dashboard</h2>
    <p class="ad-hero-sub">
      Keep your store organized with a clean premium overview. Track products, monitor orders, and handle daily admin tasks more smoothly from one place.
    </p>
  </div>

  <!-- Stats -->
  <div class="ad-stats">
    <div class="ad-stat products">
      <div class="ad-stat-top">
        <div class="ad-stat-icon">
          <i class="fa-solid fa-box-open"></i>
        </div>
        <span class="ad-stat-badge">Catalog</span>
      </div>
      <h3 class="ad-stat-number"><%= totalProducts %></h3>
      <p class="ad-stat-label">Total Products available in your store</p>
    </div>

    <div class="ad-stat orders">
      <div class="ad-stat-top">
        <div class="ad-stat-icon">
          <i class="fa-solid fa-bag-shopping"></i>
        </div>
        <span class="ad-stat-badge">Orders</span>
      </div>
      <h3 class="ad-stat-number"><%= deliveredOrders %></h3>
<p class="ad-stat-label">Orders successfully delivered</p>
    </div>

    <div class="ad-stat pending">
      <div class="ad-stat-top">
        <div class="ad-stat-icon">
          <i class="fa-solid fa-clock"></i>
        </div>
        <span class="ad-stat-badge">Pending</span>
      </div>
      <h3 class="ad-stat-number"><%= pendingOrders %></h3>
      <p class="ad-stat-label">Orders waiting for processing</p>
    </div>

    <div class="ad-stat stock">
      <div class="ad-stat-top">
        <div class="ad-stat-icon">
          <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <span class="ad-stat-badge">Stock Alert</span>
      </div>
      <h3 class="ad-stat-number"><%= lowStockCount %></h3>
      <p class="ad-stat-label">Products running low in stock</p>
    </div>
  </div>

  <!-- Main content -->
  <div class="ad-main">
    <!-- Recent Orders -->
    <div class="ad-card">
      <div class="ad-card-head">
        <div>
          <h3 class="ad-card-title">Recent Orders</h3>
          <p class="ad-card-sub">A quick look at latest customer activity in your store.</p>
        </div>
        <span class="ad-badge">Live Overview</span>
      </div>

      <div class="ad-table-wrap">
        <table class="ad-table">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Customer</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>

          <tbody>
  <% if (recentOrders && recentOrders.length > 0) { %>
    <% recentOrders.forEach(order => { %>
      <tr>
        <td class="ad-order-id">
          #ORD-<%= order._id.toString().slice(-4).toUpperCase() %>
        </td>
        <td>
          <%= order.user && order.user.name ? order.user.name : "Customer" %>
        </td>
        <td>
          Rs. <%= order.orderTotal %>
        </td>
        <td>
          <span class="ad-status <%= order.status.toLowerCase() %>">
            <%= order.status %>
          </span>
        </td>
        <td>
          <%= new Date(order.createdAt).toLocaleDateString("en-GB") %>
        </td>
      </tr>
    <% }) %>
  <% } else { %>
    <tr>
      <td colspan="5" style="text-align:center; padding:20px; color:#6b7280;">
        No recent orders found.
      </td>
    </tr>
  <% } %>
</tbody>



        </table>
      </div>
    </div>

    <!-- Side -->
    <div class="ad-side-stack">
      <!-- Quick Actions -->
      <div class="ad-card">
        <div class="ad-card-head">
          <div>
            <h3 class="ad-card-title">Quick Actions</h3>
            <p class="ad-card-sub">Fast shortcuts for common admin tasks.</p>
          </div>
          <span class="ad-badge">Shortcuts</span>
        </div>

        <div class="ad-actions-list">
          <a href="/admin/products/add" class="ad-action-btn">
            <div class="ad-action-left">
              <div class="ad-action-icon">
                <i class="fa-solid fa-plus"></i>
              </div>
              <div class="ad-action-text">
                <strong>Add New Product</strong>
                <span>Create a new product entry quickly</span>
              </div>
            </div>
            <i class="fa-solid fa-arrow-right ad-action-arrow"></i>
          </a>

          <a href="/admin/products" class="ad-action-btn">
            <div class="ad-action-left">
              <div class="ad-action-icon">
                <i class="fa-solid fa-box"></i>
              </div>
              <div class="ad-action-text">
                <strong>Manage Products</strong>
                <span>Update pricing, stock, and product details</span>
              </div>
            </div>
            <i class="fa-solid fa-arrow-right ad-action-arrow"></i>
          </a>

          <a href="/admin/orders" class="ad-action-btn">
            <div class="ad-action-left">
              <div class="ad-action-icon">
                <i class="fa-solid fa-cart-shopping"></i>
              </div>
              <div class="ad-action-text">
                <strong>View Orders</strong>
                <span>Track incoming customer orders easily</span>
              </div>
            </div>
            <i class="fa-solid fa-arrow-right ad-action-arrow"></i>
          </a>
        </div>
      </div>

      <!-- Low Stock -->
      <div class="ad-card">
        <div class="ad-card-head">
          <div>
            <h3 class="ad-card-title">Low Stock Alerts</h3>
            <p class="ad-card-sub">Products that need your attention soon.</p>
          </div>
          <span class="ad-badge">Inventory</span>
        </div>

        <div class="ad-alert-list">
  <% if (lowStockProducts && lowStockProducts.length > 0) { %>
    <% lowStockProducts.forEach(product => { %>
      <div class="ad-alert-item">
        <div class="ad-alert-left">
          <h6 class="ad-alert-title"><%= product.name %></h6>
          <p class="ad-alert-text">
            <% if (product.stock === 0) { %>
              Out of stock
            <% } else if (product.stock === 1) { %>
              Very limited quantity available
            <% } else if (product.stock <= 3) { %>
              Restock recommended soon
            <% } else { %>
              Variant stock is getting low
            <% } %>
          </p>
        </div>
        <span class="ad-alert-qty"><%= product.stock %> left</span>
      </div>
    <% }) %>
  <% } else { %>
    <div class="ad-alert-item">
      <div class="ad-alert-left">
        <h6 class="ad-alert-title">No low stock alerts</h6>
        <p class="ad-alert-text">All products currently have healthy stock levels.</p>
      </div>
      <span class="ad-alert-qty">Good</span>
    </div>
  <% } %>
</div>
  </div>

  