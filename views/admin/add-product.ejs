<style>

.ap-card{
  max-width:900px;
  margin:auto;
  background:#fff;
  border-radius:16px;
  padding:35px;
  border:1px solid #e5e7eb;
  box-shadow:0 10px 30px rgba(0,0,0,.06);
}

.ap-title{
  font-size:28px;
  font-weight:700;
  margin-bottom:5px;
}

.ap-sub{
  color:#6b7280;
  font-size:14px;
  margin-bottom:25px;
}

.ap-group{
  margin-bottom:20px;
}

.ap-label{
  font-weight:600;
  font-size:14px;
  margin-bottom:6px;
  display:block;
}

.ap-input{
  width:100%;
  padding:12px 14px;
  border-radius:10px;
  border:1px solid #e5e7eb;
  font-size:14px;
  transition:.2s;
}

.ap-input:focus{
  outline:none;
  border-color:#111827;
  box-shadow:0 0 0 3px rgba(17,24,39,.08);
}

.ap-textarea{
  min-height:110px;
  resize:vertical;
}

.ap-upload{
  padding:10px;
  border:1px dashed #d1d5db;
  border-radius:10px;
  background:#fafafa;
}

.ap-btn{
  background:#111827;
  color:#fff;
  padding:12px 22px;
  border-radius:999px;
  font-weight:600;
  border:none;
  transition:.2s;
}

.ap-btn:hover{
  background:#000;
}

.ap-row{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px;
}

@media(max-width:768px){
  .ap-row{
    grid-template-columns:1fr;
  }
}

</style>


<div class="container mt-5">

  <div class="ap-card">

    <div class="ap-title">Add New Product</div>
    <div class="ap-sub">Fill the details below to add a new product to your store.</div>

    <form action="/admin/products/add" method="POST" enctype="multipart/form-data">

      <div class="ap-group">
        <label class="ap-label">Product Name</label>
        <input type="text" name="name" class="ap-input" required>
      </div>

      <div class="ap-row">

        <div class="ap-group">
          <label class="ap-label">Category</label>
          <input type="text" name="category" class="ap-input" required>
        </div>

        <div class="ap-group">
          <label class="ap-label">Stock</label>
          <input type="number" name="stock" class="form-control" min="0" required>
        </div>

      </div>

      <div class="ap-row">

        <div class="ap-group">
          <label class="ap-label">Price</label>
          <input type="number" name="price" class="ap-input" min="0" required>
        </div>

        <div class="ap-group">
          <label class="ap-label">Product Image</label>
          <input type="file" name="image" class="ap-input ap-upload">
        </div>

      </div>

      <div class="ap-group">
        <label class="ap-label">Description</label>
        <textarea name="description" class="ap-input ap-textarea"></textarea>
      </div>

      <button type="submit" class="ap-btn">
        + Add Product
      </button>

    </form>

  </div>

</div>