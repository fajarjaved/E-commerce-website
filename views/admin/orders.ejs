<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Orders</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <style>
    :root{
      --border:#e5e7eb;
      --text:#111827;
      --muted:#6b7280;
      --shadow: 0 16px 34px rgba(0,0,0,.06);
      --radius: 16px;
    }

    body{ background:#f8fafc; }

    .or-header{
      background:#fff;
      border:1px solid var(--border);
      border-radius: 18px;
      padding: 18px 18px;
      box-shadow: 0 12px 26px rgba(0,0,0,.05);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      margin-bottom: 14px;
    }
    .or-title{
      margin:0;
      font-weight:700;
      color:var(--text);
      font-size: 30px;
      letter-spacing:.2px;
      line-height:1.1;
    }
    .or-sub{
      margin:6px 0 0;
      font-size:13px;
      color:var(--muted);
    }

    .or-card{
      background:#fff;
      border:1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow:hidden;
    }

    .or-table{
      margin:0;
      border-collapse: separate !important;
      border-spacing: 0 !important;
      font-size: 14px;
    }
    .or-table.table-bordered > :not(caption) > *{ border-width:0 !important; }

    .or-table thead th{
      position: sticky;
      top: 0;
      z-index: 2;
      background:#fff !important;
      color:#374151;
      font-weight:600;
      font-size:15px;
      padding:14px 14px !important;
      border-bottom:1px solid var(--border) !important;
      white-space:nowrap;
    }

    .or-table tbody td{
      padding:14px 14px !important;
      border-top:1px solid rgba(17,24,39,.06) !important;
      vertical-align: middle;
      color: var(--text);
      font-weight:400;
      background:#fff;
    }

    .or-row{ transition:.18s ease; }
    .or-row:hover{ background: rgba(17,24,39,.02); }

    .or-id{
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size:12px;
      padding:6px 10px;
      border-radius:999px;
      border:1px solid rgba(17,24,39,.10);
      background: rgba(17,24,39,.03);
      display:inline-block;
      max-width: 260px;
      overflow:hidden;
      text-overflow: ellipsis;
      white-space:nowrap;
    }

    .or-price{ font-weight:700; white-space:nowrap; }

    .or-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      font-weight:700;
      font-size:12px;
      border:1px solid rgba(17,24,39,.10);
      background: rgba(17,24,39,.04);
      color:#111827;
      white-space:nowrap;
      min-width: 130px;
      justify-content:center;
    }
    .or-badge.pending{ background: rgba(255,193,7,.16); border-color: rgba(255,193,7,.24); color:#7a5b00; }
    .or-badge.processing{ background: rgba(13,110,253,.12); border-color: rgba(13,110,253,.20); color:#084298; }
    .or-badge.delivered{ background: rgba(25,135,84,.12); border-color: rgba(25,135,84,.20); color:#0f5132; }
    .or-badge.cancelled{ background: rgba(220,53,69,.12); border-color: rgba(220,53,69,.20); color:#842029; }

    .or-select{
      min-width: 150px;
      border-radius: 999px;
      border:1px solid var(--border);
      padding: 9px 12px;
      font-size: 13px;
      background:#fff;
      font-weight:600;
    }
    .or-select:focus{
      outline:none;
      border-color:#111827;
      box-shadow:0 0 0 3px rgba(17,24,39,.08);
    }

    .or-btn{
      border:none;
      border-radius:999px;
      padding:10px 14px;
      font-weight:700;
      font-size:13px;
      transition:.18s ease;
      white-space:nowrap;
    }
    .or-btn:hover{ transform: translateY(-1px); }

    .or-btn-update{ background:#111827; color:#fff; }
    .or-btn-update:hover{ background:#0b1220; }

    .or-btn-details{
      background: rgba(17,24,39,.06);
      color:#111827;
      border:1px solid rgba(17,24,39,.10);
    }
    .or-btn-details:hover{ background: rgba(17,24,39,.10); }

    .or-btn-soft{
      background:#fff;
      color:#111827;
      border:1px solid rgba(17,24,39,.10);
    }
    .or-btn-soft:hover{ background: rgba(17,24,39,.03); }

    .or-empty{
      padding: 18px;
      color: var(--muted);
      font-weight:700;
      text-align:center;
    }

    .or-status-wrap{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      flex-wrap:wrap;
    }
    .or-status-form{
      display:flex;
      align-items:center;
      gap:10px;
      margin:0;
    }
    @media (min-width: 769px){ .or-status-wrap{ flex-wrap:nowrap; } }
    @media (max-width: 768px){
      .or-header{ flex-direction: column; align-items:flex-start; }
      .or-title{ font-size: 26px; }
      .or-id{ max-width: 180px; }

      .or-status-wrap{ align-items:stretch; gap:10px; }
      .or-badge{ width:100%; justify-content:flex-start; }
      .or-status-form{ width:100%; }
      .or-select{ flex:1; min-width: 0; }
    }

    .or-date{ display:flex; flex-direction:column; gap:2px; }
    .or-date-main{ font-weight:700; font-size:13px; color:#111827; }
    .or-date-sub{ font-size:12px; color:#6b7280; }

    /* Modal */
    .or-modal{
      border-radius: 18px;
      border:1px solid #e5e7eb;
      box-shadow: 0 20px 60px rgba(0,0,0,.12);
      overflow:hidden;
    }
    .or-modal-title{ font-weight:800; font-size:18px; color:#111827; }
    .or-modal-sub{
      display:flex; align-items:center; gap:10px; margin-top:6px;
      font-size:12px; color:#6b7280; flex-wrap:wrap;
    }
    .or-dot{ opacity:.6; }

    .or-info-card{
      border:1px solid #e5e7eb;
      border-radius: 14px;
      padding: 14px;
      background:#fff;
    }
    .or-info-h{
      font-size:12px; font-weight:800; color:#6b7280;
      text-transform: uppercase; letter-spacing:.6px; margin-bottom:6px;
    }
    .or-info-v{
      font-size:14px; font-weight:700; color:#111827;
      word-break: break-word;
    }
    .or-info-s{ margin-top:6px; font-size:12px; color:#6b7280; }

    .or-pill{
      display:inline-flex;
      padding: 6px 10px;
      border-radius:999px;
      border:1px solid rgba(17,24,39,.10);
      background: rgba(17,24,39,.04);
      font-weight:700;
      font-size:12px;
    }

    .or-items{ display:flex; flex-direction:column; gap:10px; }
    .or-item-row{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:14px;
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(17,24,39,.06);
      background: rgba(17,24,39,.02);
    }
    .or-item-left{
      display:flex;
      gap:10px;
      align-items:flex-start;
      min-width: 0;
    }
    .or-item-img{
      width:44px;
      height:44px;
      border-radius:12px;
      object-fit:cover;
      border:1px solid rgba(17,24,39,.08);
      background:#fff;
      flex: 0 0 auto;
    }
    .or-item-name{ font-weight:700; color:#111827; }
    .or-item-sub{ font-size:12px; color:#6b7280; margin-top:2px; }
    .or-item-price{ font-weight:800; white-space:nowrap; }

    /* Pagination */
    .pagination .page-link{
      border-radius:999px !important;
      margin-left:6px;
      border:1px solid rgba(17,24,39,.10);
      color:#111827;
      font-weight:700;
      font-size:13px;
    }
    .pagination .page-item.active .page-link{
      background:#111827;
      border-color:#111827;
      color:#fff;
    }
    .pagination .page-item.disabled .page-link{ opacity:.5; }
  </style>
</head>

<body>
  <div class="container mt-5">

    <div class="or-header">
      <div>
        <h1 class="or-title">Orders</h1>
        <p class="or-sub">Manage order statuses and keep your fulfillment flow smooth.</p>
      </div>
    </div>

    <div class="or-card">
      <div class="table-responsive">
        <table class="table or-table mb-0">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Customer</th>
              <th>Total</th>
              <th>Placed On</th>
              <th>Status</th>
              <th style="width:170px;">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if (orders && orders.length > 0) { %>
              <% orders.forEach(order => { 
                const st = (order.status || 'Pending').toLowerCase();
                const badgeClass =
                  st === 'pending' ? 'pending' :
                  st === 'processing' ? 'processing' :
                  st === 'delivered' ? 'delivered' :
                  'cancelled';

                const dt = order.createdAt ? new Date(order.createdAt) : null;
                const dateText = dt ? dt.toLocaleDateString('en-GB') : 'N/A';
                const timeText = dt ? dt.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) : '';

                const items = order.items || [];
                const addr = order.shippingAddress || '';
              %>

                <tr class="or-row">
                  <td><span class="or-id" title="<%= order._id %>"><%= order._id %></span></td>

                  <td style="font-weight:600;"><%= order.user ? order.user.name : 'N/A' %></td>

                  <td class="or-price">
                    Rs.<%= (order.orderTotal && !isNaN(order.orderTotal)) ? order.orderTotal.toFixed(2) : '0.00' %>
                  </td>

                  <td>
                    <div class="or-date">
                      <div class="or-date-main"><%= dateText %></div>
                      <div class="or-date-sub"><%= timeText %></div>
                    </div>
                  </td>

                  <td>
                    <div class="or-status-wrap">
                      <span class="or-badge <%= badgeClass %>"><%= order.status || 'Pending' %></span>

                      <form action="/admin/orders/update/<%= order._id %>" method="POST" class="or-status-form">
                        <select name="status" class="or-select">
                          <option value="Pending"    <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                          <option value="Processing" <%= order.status === 'Processing' ? 'selected' : '' %>>Processing</option>
                          <option value="Delivered"  <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                          <option value="Cancelled"  <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                        </select>
                        <button type="submit" class="or-btn or-btn-update">Update</button>
                      </form>
                    </div>
                  </td>

                  <td>
                    <button class="or-btn or-btn-details" data-bs-toggle="modal" data-bs-target="#orderModal-<%= order._id %>">
                      Details
                    </button>
                  </td>
                </tr>

                <!-- Details Modal -->
                <div class="modal fade" id="orderModal-<%= order._id %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content or-modal">
                      <div class="modal-header">
                        <div>
                          <div class="or-modal-title">Order Details</div>
                          <div class="or-modal-sub">
                            <span class="or-id" title="<%= order._id %>"><%= order._id %></span>
                            <span class="or-dot">•</span>
                            <span><%= dateText %> <%= timeText %></span>
                          </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>

                      <div class="modal-body">
                        <div class="row g-3">
                          <div class="col-md-6">
                            <div class="or-info-card">
                              <div class="or-info-h">Customer</div>
                              <div class="or-info-v"><%= order.user ? order.user.name : 'N/A' %></div>
                              <div class="or-info-s"><%= (order.user && order.user.email) ? order.user.email : '' %></div>
                              <div class="or-info-s"><%= order.phone ? ('Phone: ' + order.phone) : '' %></div>
                            </div>
                          </div>

                          <div class="col-md-6">
                            <div class="or-info-card">
                              <div class="or-info-h">Total</div>
                              <div class="or-info-v">Rs.<%= (order.orderTotal && !isNaN(order.orderTotal)) ? order.orderTotal.toFixed(2) : '0.00' %></div>
                              <div class="or-info-s">Status: <span class="or-pill"><%= order.status || 'Pending' %></span></div>
                              <div class="or-info-s">Payment: <span class="or-pill"><%= order.paymentMethod || 'cash' %></span></div>
                            </div>
                          </div>

                          <div class="col-12">
                            <div class="or-info-card">
                              <div class="or-info-h">Items</div>

                              <% if (items && items.length) { %>
                                <div class="or-items">
                                  <% items.forEach(it => { %>
                                    <div class="or-item-row">
                                      <div class="or-item-left">
                                        <img class="or-item-img" src="<%= it.image || '/images/no-image.png' %>" onerror="this.src='/images/no-image.png';" alt="">
                                        <div style="min-width:0;">
                                          <div class="or-item-name"><%= it.name %></div>
                                          <div class="or-item-sub">Qty: <%= it.quantity %></div>
                                        </div>
                                      </div>
                                      <div class="or-item-price">
                                        Rs.<%= (it.price && !isNaN(it.price)) ? Number(it.price).toFixed(2) : '0.00' %>
                                      </div>
                                    </div>
                                  <% }) %>
                                </div>
                              <% } else { %>
                                <div class="text-muted">No items found.</div>
                              <% } %>
                            </div>
                          </div>

                          <div class="col-12">
                            <div class="or-info-card">
                              <div class="or-info-h">Shipping Address</div>
                              <div class="or-info-v"><%= addr || 'N/A' %></div>
                            </div>
                          </div>
                        </div>
                      </div>

                      <div class="modal-footer">
                        <button type="button" class="or-btn or-btn-soft" data-bs-dismiss="modal">Close</button>
                      </div>
                    </div>
                  </div>
                </div>

              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="or-empty">No orders found</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
      <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
        <div style="color:#6b7280;font-size:13px;font-weight:600;">
          Page <%= page %> of <%= totalPages %> • Total <%= totalOrders %> orders
        </div>

        <nav aria-label="Orders pagination">
          <ul class="pagination mb-0">
            <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
              <a class="page-link" href="/admin/orders?page=<%= page - 1 %>">Prev</a>
            </li>

            <%
              const start = Math.max(1, page - 2);
              const end = Math.min(totalPages, page + 2);
              for(let p = start; p <= end; p++){
            %>
              <li class="page-item <%= p === page ? 'active' : '' %>">
                <a class="page-link" href="/admin/orders?page=<%= p %>"><%= p %></a>
              </li>
            <% } %>

            <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
              <a class="page-link" href="/admin/orders?page=<%= page + 1 %>">Next</a>
            </li>
          </ul>
        </nav>
      </div>
    <% } %>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>