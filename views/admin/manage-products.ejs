<style>
  :root{
    --p: #28a745;
    --p2:#1f8a3a;
    --bg:#f6f8fc;
    --card:#ffffff;
    --text:#111827;
    --muted:#6b7280;
    --border:#e5e7eb;
    --shadow: 0 14px 34px rgba(0,0,0,.08);
    --radius: 14px;
  }

  .mp-wrap{ padding: 8px 0; }

  /* HEAVY - commented
  .mp-header{
    background: linear-gradient(180deg, rgba(40,167,69,.10), rgba(40,167,69,0));
    border: 1px solid rgba(40,167,69,.18);
    border-radius: var(--radius);
    padding: 16px 16px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 12px;
    margin-bottom: 14px;
  }
  */

  /* FIX: Simple clean header (no green touch) */
  .mp-header{
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 18px 18px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 14px;
    margin-bottom: 14px;
    box-shadow: 0 12px 26px rgba(0,0,0,.05);
  }

  .mp-title{
  margin:0;
  font-weight: 700;   /* FIX */
  letter-spacing: .3px;
  color: var(--text);
  font-size: 30px;    /* thoda balanced */
}
  .mp-sub{
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  .mp-actions{
    display:flex;
    align-items:center;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* Search remove: (agar future me add ho to bhi styling ready) */
  .mp-search{ display:none; }

  .mp-btn{
    display:inline-flex;
    align-items:center;
    gap:10px;
    padding: 11px 16px;
    border-radius: 999px;
    font-weight: 800;
    border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 10px 18px rgba(0,0,0,.06);
    transition: .18s ease;
    white-space: nowrap;
  }
  .mp-btn:hover{ transform: translateY(-1px); filter: brightness(1.02); }

  /* Make CTA like your site: darker + clean */
  .mp-btn-add{
    background: #111827;
    color: #fff !important;
    text-decoration:none !important;
  }
  .mp-btn-add:hover{
    background:#0b1220;
  }

  .mp-card{
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 18px;
    box-shadow: 0 16px 34px rgba(0,0,0,.06);
    overflow: hidden;
  }

  /* FIX: Premium table (clean header, nice rows, hover, spacing) */
  .mp-table{
    margin:0;
    font-size: 14px;
    border-collapse: separate !important;
    border-spacing: 0 !important;
  }

  .mp-table thead th{
  font-weight: 600;   /* FIX */
  font-size: 15px;
  color:#374151;
}

  .mp-table tbody td{
    vertical-align: middle;
    padding: 14px 14px !important;
    color: #111827;
    border-top: 1px solid rgba(17,24,39,.06) !important;
  }
  .mp-table tbody td{
  font-size:14px;
  font-weight:400;   /* FIX */
}

  .mp-table.table-bordered > :not(caption) > *{
    border-width: 0 !important; /* bootstrap table-bordered ko clean kar diya */
  }

  .mp-row{
    transition: .18s ease;
    background: #fff;
  }
  .mp-row:hover{
    background: rgba(17,24,39,.02);
  }

  .mp-img{
    width: 56px;
    height: 56px;
    border-radius: 14px;
    object-fit: cover;
    border: 1px solid rgba(17,24,39,.08);
    box-shadow: 0 10px 18px rgba(0,0,0,.06);
    transition: .18s ease;
  }
  .mp-img:hover{ transform: scale(1.04); }

  .mp-name{
   font-weight:600;   /* FIX */
  font-size:15px;
  }
  .mp-meta{
    font-size: 12px;
    color: var(--muted);
    margin: 3px 0 0;
  }

  .mp-badge{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding: 8px 12px;
    border-radius: 999px;
    font-weight: 900;
    font-size: 12px;
    border: 1px solid rgba(17,24,39,.10);
    background: rgba(17,24,39,.04);
    color: #111827;
  }
  .mp-badge.low{
    background: rgba(255,193,7,.16);
    border-color: rgba(255,193,7,.22);
    color: #7a5b00;
  }
  .mp-badge.zero{
    background: rgba(220,53,69,.14);
    border-color: rgba(220,53,69,.20);
    color: #842029;
  }

  .mp-price{ font-weight: 900; }

  .mp-desc{
    max-width: 360px;
    color: #374151;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .mp-actions-col{
    display:flex;
    gap: 10px;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  /* Premium pills */
  .mp-mini{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding: 9px 12px;
    border-radius: 999px;
    font-weight: 900;
    font-size: 13px;
    border: 1px solid rgba(17,24,39,.10);
    text-decoration:none !important;
    transition: .18s ease;
    background: #fff;
    color: #111827 !important;
  }
  .mp-mini:hover{ transform: translateY(-1px); background: rgba(17,24,39,.03); }

  .mp-edit{
    background: rgba(255,193,7,.14);
    border-color: rgba(255,193,7,.22);
    color: #6b4e00 !important;
  }

  .mp-del{
    background: rgba(220,53,69,.12);
    border-color: rgba(220,53,69,.20);
    color: #842029 !important;
  }

  .mp-empty{
    padding: 18px;
    color: var(--muted);
    font-weight: 800;
  }

  @media (max-width: 768px){
    .mp-header{ flex-direction: column; align-items: flex-start; }
    .mp-title{ font-size: 28px; }
    .mp-desc{ max-width: 220px; }
  }









  /* Pagination */
.mp-pagination-wrap{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  padding:16px 18px;
  border-top:1px solid rgba(17,24,39,.06);
  background:#fff;
  flex-wrap:wrap;
}

.mp-page-info{
  font-size:13px;
  color:var(--muted);
  font-weight:600;
}

.mp-pagination{
  display:flex;
  align-items:center;
  gap:8px;
  flex-wrap:wrap;
}

.mp-page-link{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:40px;
  height:40px;
  padding:0 14px;
  border-radius:999px;
  border:1px solid rgba(17,24,39,.10);
  background:#fff;
  color:#111827 !important;
  text-decoration:none !important;
  font-size:13px;
  font-weight:700;
  transition:.18s ease;
  box-shadow:0 8px 16px rgba(0,0,0,.04);
}

.mp-page-link:hover{
  transform:translateY(-1px);
  background:rgba(17,24,39,.03);
}

.mp-page-link.active{
  background:#111827;
  color:#fff !important;
  border-color:#111827;
}

.mp-page-link.disabled{
  pointer-events:none;
  opacity:.45;
  background:#f3f4f6;
}

@media (max-width: 768px){
  .mp-pagination-wrap{
    flex-direction:column;
    align-items:flex-start;
  }
}



/* GOOD STOCK - GREEN */
.mp-badge.good{
    background: rgba(40,167,69,.15);
    border-color: rgba(40,167,69,.25);
    color:#1f8a3a;
}

/* LOW STOCK - RED */
.mp-badge.low{
    background: rgba(220,53,69,.15);
    border-color: rgba(220,53,69,.25);
    color:#a61b2b;
}
</style>


<div class="container mt-4 mp-wrap">

  <!-- Header -->
  <div class="mp-header">
    <div>
      <h3 class="mp-title">Manage Products</h3>
      <p class="mp-sub">Add, update, and organize your store products in one place.</p>
    </div>

    <div class="mp-actions">
      <a href="/admin/products/add" class="mp-btn mp-btn-add">
        <i class="fa-solid fa-plus"></i>
        Add New Product
      </a>
    </div>
  </div>




  <!-- Table Card -->
  <div class="mp-card">
    <div class="table-responsive">
      <table class="table mp-table table-bordered mb-0">
        <thead>
          <tr>
            <th style="width:90px;">Image</th>
            <th>Name</th>
            <th style="width:130px;">Stock</th>
            <th style="width:140px;">Price</th>
            <th>Description</th>
            <th style="width:190px;">Actions</th>
          </tr>
        </thead>

        <tbody id="mpTbody">
          <% if (products && products.length > 0) { %>
            <% products.forEach(product => { 
              const stock = Number(product.stock || 0);
              let stockClass = '';

              if(stock <= 5){
                  stockClass = 'low';   // low stock → red
              }else{
                  stockClass = 'good';  // normal stock → green
}
            %>
              <tr class="mp-row">
                <td>
                  <img
                    src="<%= product.image %>"
                    alt="<%= product.name %>"
                    class="mp-img"
                    loading="lazy"
                    onerror="this.src='https://via.placeholder.com/56?text=No+Img';"
                  />
                </td>

                <td>
                  <p class="mp-name"><%= product.name %></p>
                  <p class="mp-meta">ID: <%= product._id %></p>
                </td>

                <td>
                  <span class="mp-badge <%= stockClass %>">
                    <i class="fa-solid fa-cubes"></i>
                    <%= stock %> in stock
                  </span>
                </td>

                <td class="mp-price">Rs. <%= product.price %></td>

                <td>
                  <div class="mp-desc"><%= product.description %></div>
                </td>

                <td>
                  <div class="mp-actions-col">
                    <a href="/admin/products/edit/<%= product._id %>" class="mp-mini mp-edit">
                      <i class="fa-solid fa-pen-to-square"></i> Edit
                    </a>

                    <a
                      href="/admin/products/delete/<%= product._id %>"
                      class="mp-mini mp-del"
                      onclick="return confirm('Are you sure you want to delete this product?');"
                    >
                      <i class="fa-solid fa-trash"></i> Delete
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center mp-empty">No products found</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <% if (typeof totalPages !== "undefined" && totalPages > 1) { %>
      <div class="mp-pagination-wrap">
        <div class="mp-page-info">
          Showing page <%= page %> of <%= totalPages %>
          <% if (typeof totalProducts !== "undefined") { %>
            • Total products: <%= totalProducts %>
          <% } %>
        </div>

        <div class="mp-pagination">
          <a href="?page=<%= page - 1 %>" class="mp-page-link <%= page <= 1 ? 'disabled' : '' %>">
            <i class="fa-solid fa-angle-left"></i>
          </a>

          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="?page=<%= i %>" class="mp-page-link <%= i === page ? 'active' : '' %>">
              <%= i %>
            </a>
          <% } %>

          <a href="?page=<%= page + 1 %>" class="mp-page-link <%= page >= totalPages ? 'disabled' : '' %>">
            <i class="fa-solid fa-angle-right"></i>
          </a>
        </div>
      </div>
    <% } %>
  </div>

</div>
