<style>
  :root{
    --ep-bg:#f6f8fc;
    --ep-card:#ffffff;
    --ep-text:#111827;
    --ep-muted:#6b7280;
    --ep-border:#e5e7eb;
    --ep-dark:#111827;
    --ep-dark-2:#0b1220;
    --ep-shadow:0 16px 34px rgba(0,0,0,.06);
    --ep-radius:18px;
  }

  .ep-wrap{
    padding: 8px 0 2px;
  }

  .ep-header{
    background:#fff;
    border:1px solid var(--ep-border);
    border-radius:20px;
    padding:18px 18px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:14px;
    margin-bottom:16px;
    box-shadow:0 12px 26px rgba(0,0,0,.05);
    flex-wrap:wrap;
  }

  .ep-title{
    margin:0;
    font-size:30px;
    font-weight:700;
    color:var(--ep-text);
    letter-spacing:.2px;
  }

  .ep-sub{
    margin:6px 0 0;
    font-size:13px;
    color:var(--ep-muted);
  }

  .ep-back{
    display:inline-flex;
    align-items:center;
    gap:9px;
    padding:11px 16px;
    border-radius:999px;
    background:#fff;
    color:var(--ep-text) !important;
    border:1px solid rgba(17,24,39,.10);
    text-decoration:none !important;
    font-size:14px;
    font-weight:700;
    box-shadow:0 10px 18px rgba(0,0,0,.05);
    transition:.18s ease;
    white-space:nowrap;
  }

  .ep-back:hover{
    transform:translateY(-1px);
    background:rgba(17,24,39,.03);
  }

  .ep-card{
    background:var(--ep-card);
    border:1px solid var(--ep-border);
    border-radius:22px;
    box-shadow:var(--ep-shadow);
    overflow:hidden;
  }

  .ep-card-inner{
    padding:22px;
  }

  .ep-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:18px;
  }

  .ep-full{
    grid-column:1 / -1;
  }

  .ep-field{
    display:flex;
    flex-direction:column;
    gap:8px;
  }

  .ep-label{
    font-size:14px;
    font-weight:600;
    color:#374151;
    margin:0;
  }

  .ep-input,
  .ep-textarea,
  .ep-file{
    width:100%;
    border:1px solid var(--ep-border);
    border-radius:14px;
    background:#fff;
    color:var(--ep-text);
    padding:13px 14px;
    font-size:14px;
    outline:none;
    transition:.18s ease;
    box-shadow:inset 0 1px 0 rgba(255,255,255,.7);
  }

  .ep-input:focus,
  .ep-textarea:focus,
  .ep-file:focus{
    border-color:#cfd7e3;
    box-shadow:0 0 0 4px rgba(17,24,39,.04);
  }

  .ep-textarea{
    min-height:130px;
    resize:vertical;
    line-height:1.65;
  }

  .ep-img-card{
    border:1px solid rgba(17,24,39,.08);
    border-radius:18px;
    padding:14px;
    background:linear-gradient(180deg, #ffffff, #fbfcfe);
    display:flex;
    align-items:center;
    gap:14px;
    min-height:110px;
  }

  .ep-img{
    width:88px;
    height:88px;
    object-fit:cover;
    border-radius:16px;
    border:1px solid rgba(17,24,39,.08);
    box-shadow:0 10px 18px rgba(0,0,0,.06);
    flex-shrink:0;
  }

  .ep-img-meta h6{
    margin:0 0 6px;
    font-size:15px;
    font-weight:700;
    color:var(--ep-text);
  }

  .ep-img-meta p{
    margin:0;
    font-size:13px;
    color:var(--ep-muted);
    line-height:1.6;
  }

  .ep-actions{
    display:flex;
    align-items:center;
    justify-content:flex-end;
    gap:12px;
    margin-top:22px;
    flex-wrap:wrap;
  }

  .ep-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    padding:12px 18px;
    border-radius:999px;
    font-size:14px;
    font-weight:700;
    text-decoration:none !important;
    border:1px solid rgba(17,24,39,.10);
    transition:.18s ease;
    white-space:nowrap;
  }

  .ep-btn-light{
    background:#fff;
    color:var(--ep-text) !important;
    box-shadow:0 10px 18px rgba(0,0,0,.05);
  }

  .ep-btn-light:hover{
    transform:translateY(-1px);
    background:rgba(17,24,39,.03);
  }

  .ep-btn-primary{
    background:var(--ep-dark);
    color:#fff !important;
    border-color:var(--ep-dark);
    box-shadow:0 12px 22px rgba(17,24,39,.16);
  }

  .ep-btn-primary:hover{
    background:var(--ep-dark-2);
    transform:translateY(-1px);
  }

  .ep-note{
    margin-top:16px;
    background:#fff;
    border:1px solid var(--ep-border);
    border-radius:18px;
    padding:14px 16px;
    color:var(--ep-muted);
    font-size:13px;
    line-height:1.7;
    box-shadow:0 8px 18px rgba(0,0,0,.04);
  }

  @media (max-width: 768px){
    .ep-grid{
      grid-template-columns:1fr;
    }

    .ep-title{
      font-size:27px;
    }

    .ep-card-inner{
      padding:18px;
    }

    .ep-actions{
      justify-content:stretch;
    }

    .ep-btn{
      width:100%;
    }

    .ep-img-card{
      align-items:flex-start;
      flex-direction:column;
    }
  }
</style>

<div class="container mt-4 ep-wrap">

  <div class="ep-header">
    <div>
      <h1 class="ep-title">Edit Product</h1>
      <p class="ep-sub">Update product details, stock, category, description, and image from one clean form.</p>
    </div>

    <a href="/admin/products" class="ep-back">
      <i class="fa-solid fa-arrow-left"></i>
      Back to Products
    </a>
  </div>

  

  <div class="ep-card">
    <div class="ep-card-inner">
      <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">

        <div class="ep-grid">
          <div class="ep-field">
            <label class="ep-label">Product Name</label>
            <input
              type="text"
              name="name"
              value="<%= product.name %>"
              class="ep-input"
              required
            >
          </div>

          <div class="ep-field">
            <label class="ep-label">Price</label>
            <input
              type="number"
              name="price"
              value="<%= product.price %>"
              class="ep-input"
              required
            >
          </div>

          <div class="ep-field">
            <label class="ep-label">Stock</label>
            <input
                type="number"
                name="stock"
                value="<%= typeof product.stock !== 'undefined' ? product.stock : 0 %>"
                class="ep-input"
                min="0"
                required
            >
          </div>

          <div class="ep-field">
            <label class="ep-label">Category</label>
            <input
              list="categories"
              name="category"
              class="ep-input"
              value="<%= product.category %>"
            >

            <datalist id="categories">
              <% categories.forEach(cat => { %>
                <option value="<%= cat.name %>">
              <% }) %>
            </datalist>
          </div>

          <div class="ep-field ep-full">
            <label class="ep-label">Description</label>
            <textarea
              name="description"
              class="ep-textarea"
              required
            ><%= product.description %></textarea>
          </div>

          <div class="ep-field">
            <label class="ep-label">Current Image</label>
            <div class="ep-img-card">
              <img src="<%= product.image %>" alt="Product Image" class="ep-img">
              <div class="ep-img-meta">
                <h6>Current Product Image</h6>
                <p>This is the image currently attached to this product. Upload a new one only if you want to replace it.</p>
              </div>
            </div>
          </div>

          <div class="ep-field">
            <label class="ep-label">Change Image</label>
            <input type="file" name="image" class="ep-file">
          </div>
        </div>

        <div class="ep-actions">
          <a href="/admin/products" class="ep-btn ep-btn-light">
            <i class="fa-solid fa-xmark"></i>
            Cancel
          </a>

          <button type="submit" class="ep-btn ep-btn-primary">
            <i class="fa-solid fa-floppy-disk"></i>
            Update Product
          </button>
        </div>
      </form>
    </div>
  </div>

  

</div>